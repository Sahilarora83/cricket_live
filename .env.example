NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173

# cricbuzz or mock
CRICKET_PROVIDER=cricbuzz
CRICBUZZ_LIVE_URL=https://www.cricbuzz.com/cricket-match/live-scores
CRICBUZZ_BASE_URL=https://www.cricbuzz.com

# Optional in local development. The app falls back to memory cache if Redis is unavailable.
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/cricket_live

MATCH_SCHEDULER_INTERVAL_MS=60000
SCORE_UPDATER_INTERVAL_MS=5000
SERIES_SCRAPER_INTERVAL_MS=600000
COMMENTARY_LIMIT=30

# Optional, ready for Firebase Cloud Messaging integration.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
